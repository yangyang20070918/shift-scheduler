          "title": "Date",
          "type": "string"
        },
        "min_total": {
          "default": 0,
          "title": "Min Total",
          "type": "integer"
        },
        "max_total": {
          "default": 999,
          "title": "Max Total",
          "type": "integer"
        }
      },
      "required": [
        "date"
      ],
      "title": "DailyDemand",
      "type": "object"
    },
    "FixedAssignment": {
      "properties": {
        "member_id": {
          "title": "Member Id",
          "type": "string"
        },
        "date": {
